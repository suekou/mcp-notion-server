{
  "name": "@suekou/mcp-notion-server",
  "version": "2.0.0",
  "description": "AI-friendly MCP server for the Notion API",
  "license": "MIT",
  "author": "Kosuke Suenaga (https://github.com/suekou/mcp-notion-server)",
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10.24.0"
  },
  "main": "build/index.js",
  "bin": {
    "mcp-notion-server": "build/index.js"
  },
  "files": [
    "build",
    "docs",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/suekou/mcp-notion-server"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && node scripts/build-apps.mjs",
    "build:apps": "node scripts/build-apps.mjs",
    "prepare": "pnpm run build",
    "watch": "tsc --watch",
    "inspector": "pnpm dlx @modelcontextprotocol/inspector build/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "format": "biome format --write",
    "format:check": "biome format",
    "check": "biome check",
    "check:fix": "biome check --write"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "yargs": "^17.7.2",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "^25.7.0",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@types/yargs": "^17.0.33",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "10.5.0",
    "postcss": "8.4.49",
    "tailwindcss": "4.3.0",
    "typescript": "^6.0.3",
    "vite": "5.4.21",
    "vite-plugin-singlefile": "2.3.3",
    "vitest": "4.1.6"
  }
}
